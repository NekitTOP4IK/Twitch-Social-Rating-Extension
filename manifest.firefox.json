{
  "manifest_version": 2,
  "name": "Twitch Social Rating",
  "version": "__VERSION__",
  "description": "Shows social rating for Twitch chat users",
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "storage",
    "downloads",
    "tabs",
    "activeTab",
    "https://www.twitch.tv/*",
    "https://dashboard.twitch.tv/*",
    "__BACKEND_URL__/*",
    "__WS_BACKEND_URL__/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.twitch.tv/*",
        "https://dashboard.twitch.tv/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "twitch-social-rating@socialrating.app",
      "update_url": "__FIREFOX_UPDATE_URL__"
    }
  },
  "content_security_policy": "script-src 'self'; object-src 'self'; connect-src 'self' __BACKEND_ORIGIN__ __WS_BACKEND_ORIGIN__",
  "browser_action": {
    "default_popup": "popup.html"
  }
}
