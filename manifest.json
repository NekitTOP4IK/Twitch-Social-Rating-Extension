{
  "manifest_version": 3,
  "name": "Twitch Social Rating",
  "version": "0.1.0",
  "description": "Shows social rating for Twitch chat users",
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": ["storage", "identity"],
  "host_permissions": [
    "https://www.twitch.tv/*",
    "https://dashboard.twitch.tv/*",
    "https://api.socialrating.app/*",
    "http://localhost:8000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.twitch.tv/*",
        "https://dashboard.twitch.tv/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
