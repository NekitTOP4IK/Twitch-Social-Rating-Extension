{
  "manifest_version": 2,
  "name": "Twitch Social Rating",
  "version": "0.1.0",
  "description": "Shows social rating for Twitch chat users",
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "https://www.twitch.tv/*",
    "https://dashboard.twitch.tv/*",
    "https://api.socialrating.app/*",
    "http://localhost:8000/*",
    "ws://localhost:8000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.twitch.tv/*",
        "https://dashboard.twitch.tv/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_security_policy": "script-src 'self'; object-src 'self'; connect-src 'self' http://localhost:8000 ws://localhost:8000 https://api.socialrating.app wss://api.socialrating.app",
  "browser_action": {
    "default_popup": "popup.html"
  }
}
